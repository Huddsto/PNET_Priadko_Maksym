@using System.ComponentModel.DataAnnotations
@using StudentsBlazorApp.Components.Pages.Dashboard

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h2 class="h4 mb-3">Courses</h2>

        <EditForm Model="courseForm" OnValidSubmit="SubmitAdd" FormName="add-course-form">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="row g-2 mb-4">
                <div class="col-md-3">
                    <InputText class="form-control" @bind-Value="courseForm.Title" placeholder="Title" />
                </div>
                <div class="col-md-3">
                    <InputText class="form-control" @bind-Value="courseForm.Description" placeholder="Description" />
                </div>
                <div class="col-md-3">
                    <InputText class="form-control" @bind-Value="courseForm.TeacherName" placeholder="Teacher Name" />
                </div>
                <div class="col-md-2">
                    <InputText class="form-control" @bind-Value="courseForm.Department" placeholder="Department" />
                </div>
                <div class="col-md-1">
                    <button class="btn btn-primary w-100" type="submit">Add</button>
                </div>
            </div>
        </EditForm>

        @if (Courses.Count == 0)
        {
            <div class="text-muted">No courses found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>Description</th>
                            <th>Teacher</th>
                            <th>Department</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Courses)
                        {
                            <tr>
                                <td>@course.Title</td>
                                <td>@(string.IsNullOrWhiteSpace(course.Description) ? "-" : course.Description)</td>
                                <td>@(course.Teacher?.Name ?? "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(course.Teacher?.Department) ? "-" : course.Teacher?.Department)</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => OnDeleteCourse.InvokeAsync(course.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<Course> Courses { get; set; } = [];
    [Parameter] public EventCallback<CourseCreateRequest> OnAddCourse { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteCourse { get; set; }

    private readonly CourseFormModel courseForm = new();

    private async Task SubmitAdd()
    {
        await OnAddCourse.InvokeAsync(new CourseCreateRequest(
            courseForm.Title,
            courseForm.Description,
            courseForm.TeacherName,
            courseForm.Department));

        courseForm.Title = string.Empty;
        courseForm.Description = null;
        courseForm.TeacherName = string.Empty;
        courseForm.Department = null;
    }

    private sealed class CourseFormModel
    {
        [Required]
        public string Title { get; set; } = string.Empty;

        public string? Description { get; set; }

        [Required]
        public string TeacherName { get; set; } = string.Empty;

        public string? Department { get; set; }
    }
}
