@using System.ComponentModel.DataAnnotations
@using StudentsBlazorApp.Components.Pages.Dashboard

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <h2 class="h4 mb-0">Students</h2>
            <div class="d-flex gap-2">
                <input class="form-control" style="min-width: 240px;" placeholder="Search students" @bind="studentSearch" />
            </div>
        </div>

        <EditForm Model="studentForm" OnValidSubmit="SubmitAdd" FormName="add-student-form">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="row g-2 mb-4">
                <div class="col-md-4">
                    <InputText class="form-control" @bind-Value="studentForm.Name" placeholder="Name" />
                </div>
                <div class="col-md-4">
                    <InputText class="form-control" @bind-Value="studentForm.Email" placeholder="Email" />
                </div>
                <div class="col-md-2">
                    <InputNumber class="form-control" @bind-Value="studentForm.Age" placeholder="Age" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" type="submit">Add Student</button>
                </div>
            </div>
        </EditForm>

        @if (FilteredStudents.Count == 0)
        {
            <div class="text-muted">No students found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Age</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in FilteredStudents)
                        {
                            <tr>
                                <td>@student.Name</td>
                                <td>@student.Email</td>
                                <td>@(student.Age?.ToString() ?? "-")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-sm btn-warning" @onclick="() => StartEdit(student)">Edit</button>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => OnDeleteStudent.InvokeAsync(student.Id)">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (editingStudentId.HasValue)
{
    <div class="card shadow-sm">
        <div class="card-body">
            <h3 class="h5 mb-3">Edit Student</h3>
            <EditForm Model="editStudentForm" OnValidSubmit="SubmitEdit" FormName="edit-student-form">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="row g-2">
                    <div class="col-md-4">
                        <InputText class="form-control" @bind-Value="editStudentForm.Name" placeholder="Name" />
                    </div>
                    <div class="col-md-4">
                        <InputText class="form-control" @bind-Value="editStudentForm.Email" placeholder="Email" />
                    </div>
                    <div class="col-md-2">
                        <InputNumber class="form-control" @bind-Value="editStudentForm.Age" placeholder="Age" />
                    </div>
                    <div class="col-md-2 d-flex gap-2">
                        <button class="btn btn-success flex-fill" type="submit">Save</button>
                        <button class="btn btn-outline-secondary flex-fill" type="button" @onclick="CancelEdit">Cancel</button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<Student> Students { get; set; } = [];
    [Parameter] public EventCallback<StudentUpsertRequest> OnAddStudent { get; set; }
    [Parameter] public EventCallback<StudentUpdateRequest> OnUpdateStudent { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteStudent { get; set; }

    private readonly StudentFormModel studentForm = new();
    private readonly StudentFormModel editStudentForm = new();
    private string studentSearch = string.Empty;
    private Guid? editingStudentId;

    private List<Student> FilteredStudents =>
        Students
            .Where(s =>
                string.IsNullOrWhiteSpace(studentSearch) ||
                s.Name.Contains(studentSearch, StringComparison.OrdinalIgnoreCase) ||
                s.Email.Contains(studentSearch, StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.Name)
            .ToList();

    private async Task SubmitAdd()
    {
        await OnAddStudent.InvokeAsync(new StudentUpsertRequest(
            studentForm.Name,
            studentForm.Email,
            studentForm.Age));

        studentForm.Name = string.Empty;
        studentForm.Email = string.Empty;
        studentForm.Age = null;
    }

    private void StartEdit(Student student)
    {
        editingStudentId = student.Id;
        editStudentForm.Name = student.Name;
        editStudentForm.Email = student.Email;
        editStudentForm.Age = student.Age;
    }

    private async Task SubmitEdit()
    {
        if (!editingStudentId.HasValue)
        {
            return;
        }

        await OnUpdateStudent.InvokeAsync(new StudentUpdateRequest(
            editingStudentId.Value,
            editStudentForm.Name,
            editStudentForm.Email,
            editStudentForm.Age));

        CancelEdit();
    }

    private void CancelEdit()
    {
        editingStudentId = null;
        editStudentForm.Name = string.Empty;
        editStudentForm.Email = string.Empty;
        editStudentForm.Age = null;
    }

    private sealed class StudentFormModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        public int? Age { get; set; }
    }
}
