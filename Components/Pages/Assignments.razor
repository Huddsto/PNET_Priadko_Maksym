@page "/assignments"
@using Microsoft.EntityFrameworkCore
@inject AppDbContext db

<PageTitle>Assignments</PageTitle>

<h2 class="mb-3">Assignments</h2>

@if (assignments.Count == 0)
{
    <div class="alert alert-info">No assignments found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Course</th>
                <th>Due Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var assignment in assignments)
            {
                <tr>
                    <td>@assignment.Title</td>
                    <td>@(assignment.Course?.Title ?? "-")</td>
                    <td>@(assignment.DueDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Assignment> assignments = new();

    protected override async Task OnInitializedAsync()
    {
        assignments = await db.Assignments
            .AsNoTracking()
            .Include(a => a.Course)
            .OrderBy(a => a.Title)
            .ToListAsync();
    }
}
